# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/
DB_NAME=car-hire

PORT=3001
NODE_ENV=development

# KCB Buni (MpesaExpress STK) — https://buni.kcbgroup.com/
KCB_BUNI_CONSUMER_KEY=
KCB_BUNI_CONSUMER_SECRET=
KCB_BUNI_ORG_SHORTCODE=522533
# STK invoiceNumber: {accountNumber}-{reference} e.g. 7888067-BK12345678
KCB_BUNI_ACCOUNT_NUMBER=7888067
KCB_BUNI_ENV=sandbox
KCB_BUNI_CALLBACK_URL=https://your-site.netlify.app/api/mpesa/callback

# Cloudinary, JWT, Twilio — see car-hire-main/backend/.env.example for full list
