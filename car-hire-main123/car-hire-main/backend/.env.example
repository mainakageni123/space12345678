# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/
DB_NAME=car-hire

# Server
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:5173

# Twilio WhatsApp (https://console.twilio.com/)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
ADMIN_WHATSAPP_NUMBER=whatsapp:+254XXXXXXXXX
# Public URL Twilio calls for webhook signature (use ngrok URL in dev)
TWILIO_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app

# M-Pesa Daraja (https://developer.safaricom.co.ke/)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://your-ngrok-url.ngrok-free.app/api/mpesa/callback
MPESA_ENV=sandbox

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT
JWT_SECRET=your_jwt_secret
